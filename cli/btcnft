#!/bin/bash
# BTCNFT Protocol CLI - Main Entrypoint
# Usage: ./btcnft [--network <network>] <command> [args...]

set -e

CLI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CLI_DIR/lib/network.sh"

# Version
readonly VERSION="2.0.0"

# Show help
show_help() {
    cat << EOF
BTCNFT Protocol CLI v${VERSION}

Usage: ./btcnft [--network <network>] <command> [args...]

Options:
  --network <network>   Target network: local, sepolia, holesky, base (default: local)
  --help, -h           Show this help message
  --version, -v        Show version

Commands:
  Setup & Deployment:
    setup                      Deploy contracts (local only)

  Vault (Single-Collateral):
    mint                       Create vault
    withdraw                   Withdraw collateral
    early-redeem               Early exit with penalty
    separate                   Mint vBTC from vault
    recombine                  Return vBTC to vault
    claim-match                Claim match pool share

  Hybrid Vault (Dual-Collateral):
    hybrid-mint                Create hybrid vault
    hybrid-withdraw-primary    Withdraw primary collateral
    hybrid-withdraw-secondary  Withdraw secondary collateral (one-time)
    hybrid-early-redeem        Early exit hybrid vault
    hybrid-separate            Mint vBTC from hybrid vault
    hybrid-recombine           Return vBTC to hybrid vault
    hybrid-claim-primary-match Claim primary match pool
    hybrid-claim-secondary-match Claim secondary match pool

  Delegation:
    delegate-grant             Grant wallet-level delegation
    delegate-revoke            Revoke wallet-level delegation
    delegate-withdraw          Withdraw as wallet delegate
    vault-delegate-grant       Grant vault-specific delegation
    vault-delegate-revoke      Revoke vault-specific delegation
    hybrid-delegate-withdraw   Withdraw as hybrid delegate

  Dormancy:
    poke                       Initiate dormancy claim
    prove-activity             Prove vault activity
    claim-dormant              Claim dormant collateral
    hybrid-poke                Initiate hybrid dormancy
    hybrid-prove-activity      Prove hybrid vault activity
    hybrid-claim-dormant       Claim dormant hybrid collateral

  Token Operations:
    token-approve              Approve ERC-20 spending

  Queries:
    status                     Show vault status
    hybrid-status              Show hybrid vault status
    delegates                  Show vault delegates
    hybrid-delegates           Show hybrid vault delegates
    batch-status               Batch vault status
    token-balance              Show token balance/allowance

  Development (local only):
    time-skip                  Fast-forward time

Examples:
  ./btcnft setup                                    # Deploy contracts locally
  ./btcnft mint 1 100000000                         # Mint vault with 1 BTC
  ./btcnft hybrid-mint 0 100000000 50000000         # Mint hybrid vault
  ./btcnft --network sepolia status 1               # Check vault 1 on Sepolia
  ./btcnft delegate-grant 1 0x... 5000              # Grant 50% withdrawal rights
  ./btcnft vault-delegate-grant 1 0x... 5000 2592000 # Grant 50% for 30 days

EOF
}

# Show version
show_version() {
    echo "BTCNFT Protocol CLI v${VERSION}"
}

# Main entrypoint
main() {
    # Handle global flags
    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --version|-v)
            show_version
            exit 0
            ;;
    esac

    # Parse network flag and get remaining args
    local args
    args=$(parse_network_args "$@")

    # Convert to array
    read -ra ARGS <<< "$args"

    # Get command
    local command="${ARGS[0]:-}"

    if [[ -z "$command" ]]; then
        show_help
        exit 1
    fi

    # Remove command from args
    REMAINING_ARGS=("${ARGS[@]:1}")
    export REMAINING_ARGS
    export CURRENT_NETWORK
    export COMMAND_NAME="btcnft $command"

    # Route to appropriate script
    case "$command" in
        # Setup
        setup)
            if ! is_local_network; then
                echo "Error: setup is only available on local network" >&2
                exit 1
            fi
            exec "$CLI_DIR/commands/setup.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Vault (Single-Collateral)
        mint)
            exec "$CLI_DIR/commands/mint.sh" "${REMAINING_ARGS[@]}"
            ;;
        withdraw)
            exec "$CLI_DIR/commands/withdraw.sh" "${REMAINING_ARGS[@]}"
            ;;
        early-redeem)
            exec "$CLI_DIR/commands/early-redeem.sh" "${REMAINING_ARGS[@]}"
            ;;
        separate)
            exec "$CLI_DIR/commands/separate.sh" "${REMAINING_ARGS[@]}"
            ;;
        recombine)
            exec "$CLI_DIR/commands/recombine.sh" "${REMAINING_ARGS[@]}"
            ;;
        claim-match)
            exec "$CLI_DIR/commands/claim-match.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Hybrid Vault (Dual-Collateral)
        hybrid-mint)
            exec "$CLI_DIR/commands/hybrid-mint.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-withdraw-primary)
            exec "$CLI_DIR/commands/hybrid-withdraw-primary.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-withdraw-secondary)
            exec "$CLI_DIR/commands/hybrid-withdraw-secondary.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-early-redeem)
            exec "$CLI_DIR/commands/hybrid-early-redeem.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-separate)
            exec "$CLI_DIR/commands/hybrid-separate.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-recombine)
            exec "$CLI_DIR/commands/hybrid-recombine.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-claim-primary-match)
            exec "$CLI_DIR/commands/hybrid-claim-primary-match.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-claim-secondary-match)
            exec "$CLI_DIR/commands/hybrid-claim-secondary-match.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Delegation
        delegate-grant)
            exec "$CLI_DIR/commands/delegate-grant.sh" "${REMAINING_ARGS[@]}"
            ;;
        delegate-revoke)
            exec "$CLI_DIR/commands/delegate-revoke.sh" "${REMAINING_ARGS[@]}"
            ;;
        delegate-withdraw)
            exec "$CLI_DIR/commands/delegate-withdraw.sh" "${REMAINING_ARGS[@]}"
            ;;
        vault-delegate-grant)
            exec "$CLI_DIR/commands/vault-delegate-grant.sh" "${REMAINING_ARGS[@]}"
            ;;
        vault-delegate-revoke)
            exec "$CLI_DIR/commands/vault-delegate-revoke.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-delegate-withdraw)
            exec "$CLI_DIR/commands/hybrid-delegate-withdraw.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Dormancy
        poke)
            exec "$CLI_DIR/commands/poke.sh" "${REMAINING_ARGS[@]}"
            ;;
        prove-activity)
            exec "$CLI_DIR/commands/prove-activity.sh" "${REMAINING_ARGS[@]}"
            ;;
        claim-dormant)
            exec "$CLI_DIR/commands/claim-dormant.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-poke)
            exec "$CLI_DIR/commands/hybrid-poke.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-prove-activity)
            exec "$CLI_DIR/commands/hybrid-prove-activity.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-claim-dormant)
            exec "$CLI_DIR/commands/hybrid-claim-dormant.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Token Operations
        token-approve)
            exec "$CLI_DIR/commands/token-approve.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Queries
        status)
            exec "$CLI_DIR/queries/status.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-status)
            exec "$CLI_DIR/queries/hybrid-status.sh" "${REMAINING_ARGS[@]}"
            ;;
        delegates)
            exec "$CLI_DIR/queries/delegates.sh" "${REMAINING_ARGS[@]}"
            ;;
        hybrid-delegates)
            exec "$CLI_DIR/queries/hybrid-delegates.sh" "${REMAINING_ARGS[@]}"
            ;;
        batch-status)
            exec "$CLI_DIR/queries/batch-status.sh" "${REMAINING_ARGS[@]}"
            ;;
        token-balance)
            exec "$CLI_DIR/queries/token-balance.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Development
        time-skip)
            if ! is_local_network; then
                echo "Error: time-skip is only available on local network" >&2
                exit 1
            fi
            exec "$CLI_DIR/dev/time-skip.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Unknown command
        *)
            echo "Error: Unknown command '$command'" >&2
            echo "Run './btcnft --help' for usage" >&2
            exit 1
            ;;
    esac
}

main "$@"
