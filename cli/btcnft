#!/bin/bash
# BTCNFT Protocol CLI - Main Entrypoint
# Usage: ./btcnft [--network <network>] <command> [args...]

set -e

CLI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CLI_DIR/lib/network.sh"

# Version
readonly VERSION="2.0.0"

# Show help
show_help() {
    cat << EOF
BTCNFT Protocol CLI v${VERSION}

Usage: ./btcnft [--network <network>] <command> [args...]

Options:
  --network <network>   Target network: local, sepolia, holesky, base (default: local)
  --help, -h           Show this help message
  --version, -v        Show version

Commands:
  Setup & Deployment:
    setup                      Deploy contracts (local only)

  Vault (Single-Collateral):
    mint                       Create vault
    withdraw                   Withdraw collateral
    early-redeem               Early exit with penalty
    strip                      Move collateral to reserve (mint vBTC)
    recombine                  Move reserve back to collateral (burn vBTC)
    claim-match                Settle match pool share

  Hybrid Vault (Dual-Collateral):
    hybrid-mint                Create hybrid vault
    hybrid-withdraw-primary    Withdraw primary collateral
    hybrid-withdraw-secondary  Withdraw secondary collateral (one-time)
    hybrid-early-redeem        Early exit hybrid vault
    hybrid-strip               Move primary collateral to reserve (mint vBTC)
    hybrid-recombine           Move primary reserve back to collateral (burn vBTC)
    hybrid-claim-primary-match Settle primary match pool
    hybrid-claim-secondary-match Settle secondary match pool

  Delegation:
    delegate-grant             Grant wallet-level delegation
    delegate-revoke            Revoke wallet-level delegation
    delegate-withdraw          Withdraw as wallet delegate
    vault-delegate-grant       Grant vault-specific delegation
    vault-delegate-revoke      Revoke vault-specific delegation
    hybrid-delegate-withdraw   Withdraw as hybrid delegate

  Dormancy:
    poke                       Initiate dormancy claim
    prove-activity             Prove vault activity
    claim-dormant              Claim dormant collateral
    hybrid-poke                Initiate hybrid dormancy
    hybrid-prove-activity      Prove hybrid vault activity
    hybrid-claim-dormant       Claim dormant hybrid collateral

  Token Operations:
    token-approve              Approve ERC-20 spending

  Queries:
    status                     Show vault status
    hybrid-status              Show hybrid vault status
    delegates                  Show vault delegates
    hybrid-delegates           Show hybrid vault delegates
    batch-status               Batch vault status
    token-balance              Show token balance/allowance

  Development (local only):
    time-skip                  Fast-forward time

Examples:
  ./btcnft setup                                    # Deploy contracts locally
  ./btcnft mint 1 100000000                         # Mint vault with 1 BTC
  ./btcnft hybrid-mint 0 100000000 50000000         # Mint hybrid vault
  ./btcnft --network sepolia status 1               # Check vault 1 on Sepolia
  ./btcnft delegate-grant 1 0x... 5000              # Grant 50% withdrawal rights
  ./btcnft vault-delegate-grant 1 0x... 5000 2592000 # Grant 50% for 30 days

EOF
}

# Show version
show_version() {
    echo "BTCNFT Protocol CLI v${VERSION}"
}

# Main entrypoint
main() {
    # Handle global flags
    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --version|-v)
            show_version
            exit 0
            ;;
    esac

    # Parse network flag and get remaining args
    local args
    args=$(parse_network_args "$@")

    # Convert to array
    read -ra ARGS <<< "$args"

    # Get command
    local command="${ARGS[0]:-}"

    if [[ -z "$command" ]]; then
        show_help
        exit 1
    fi

    # Remove command from args
    REMAINING_ARGS=("${ARGS[@]:1}")
    export REMAINING_ARGS
    export CURRENT_NETWORK
    export COMMAND_NAME="btcnft $command"

    # Route to appropriate script
    case "$command" in
        # Local-only guards
        setup|time-skip)
            if ! is_local_network; then
                echo "Error: $command is only available on local network" >&2
                exit 1
            fi
            ;;
    esac

    if [[ "$command" == "time-skip" ]]; then
        exec "$CLI_DIR/dev/time-skip.sh" "${REMAINING_ARGS[@]}"
    fi

    # Command names map 1:1 to script filenames
    local d f
    for d in commands queries; do
        f="$CLI_DIR/$d/$command.sh"
        if [[ -x "$f" ]]; then
            exec "$f" "${REMAINING_ARGS[@]}"
        fi
    done

    echo "Error: Unknown command '$command'" >&2
    echo "Run './btcnft --help' for usage" >&2
    exit 1
}

main "$@"
