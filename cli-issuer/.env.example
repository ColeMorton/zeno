# BTCNFT Issuer CLI - Environment Configuration
# Copy this file to .env (local), .env.sepolia, .env.holesky, or .env.base

# RPC URL (optional - defaults to network setting if not specified)
# RPC_URL=http://127.0.0.1:8545

# Private key for signing transactions
# WARNING: Never commit real private keys to version control
PRIVATE_KEY=0x...

# Protocol Contracts (required - shared with protocol CLI)
WBTC=0x...
CBBTC=0x...
BTC_TOKEN=0x...
VAULT=0x...
TREASURE=0x...

# Issuer Contracts
AUCTION_CONTROLLER=0x...
VAULT_MINT_CONTROLLER=0x...
HYBRID_MINT_CONTROLLER=0x...
PERP_VAULT=0x...
VOL_POOL=0x...
ACHIEVEMENT_NFT=0x...
ACHIEVEMENT_MINTER=0x...
CHAPTER_REGISTRY=0x...
CHAPTER_MINTER=0x...
PROFILE_REGISTRY=0x...
DASHBOARD_NFT=0x...
SABLIER_WRAPPER=0x...
TREASURE_NFT=0x...
