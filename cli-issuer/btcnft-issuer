#!/bin/bash
# BTCNFT Issuer CLI - Main Entrypoint
# Usage: ./btcnft-issuer [--network <network>] <command> [args...]

set -e

CLI_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$CLI_DIR/../cli/lib/network.sh"

# Version
readonly VERSION="1.0.0"

# Show help
show_help() {
    cat << EOF
BTCNFT Issuer CLI v${VERSION}

Usage: ./btcnft-issuer [--network <network>] <command> [args...]

Options:
  --network <network>   Target network: local, sepolia, holesky, base (default: local)
  --help, -h           Show this help message
  --version, -v        Show version

Commands:
  Mint Controllers:
    mint-vault                 Mint vault via controller
    mint-hybrid                Mint hybrid vault via controller

  Auctions:
    auction-create-dutch       Create Dutch auction
    auction-create-english     Create English auction
    auction-purchase           Purchase from Dutch auction
    auction-bid                Place bid on English auction
    auction-settle             Settle English auction slot

  Perpetuals:
    perp-open                  Open leveraged position
    perp-close                 Close perpetual position
    perp-add-collateral        Add collateral to position

  Volatility Pool:
    vol-deposit                Deposit to long/short pool
    vol-withdraw               Withdraw from long/short pool
    vol-settle                 Trigger variance settlement

  Achievements:
    achieve-minter             Claim minter achievement
    achieve-matured            Claim matured achievement
    achieve-duration           Claim duration achievement
    achieve-hodler-supreme     Mint Hodler Supreme vault

  Chapters:
    chapter-claim              Claim chapter achievement
    chapter-create             Create new chapter (admin)
    chapter-add-achievement    Add achievement to chapter (admin)
    chapter-set-active         Toggle chapter active state (admin)

  Profile & Dashboard:
    profile-create             Create on-chain profile
    dashboard-mint             Purchase dashboard feature

  Streaming:
    stream-configure           Configure vault for streaming
    stream-create              Create stream from vault
    stream-batch               Batch create streams

  Treasure NFT:
    treasure-mint              Mint treasure NFT(s)
    treasure-authorize         Authorize/revoke minter (admin)

  Queries:
    auction-status             Query auction details
    perp-position              Show perpetual position
    perp-market                Show perpetual market state
    vol-pool-status            Show volatility pool state
    vol-position               Show volatility pool position
    achieve-check              Check achievement eligibility
    achieve-status             Show achievement status
    chapter-claimable          Show claimable chapter achievements
    chapter-info               Show chapter details
    profile-status             Show profile status
    dashboard-features         Show dashboard features
    stream-status              Show stream configuration
    treasure-status            Show treasure NFT status

Examples:
  ./btcnft-issuer mint-vault 100000000              # Mint vault via controller
  ./btcnft-issuer perp-open 50000000 200 long       # Open 2x long perp
  ./btcnft-issuer vol-deposit long 100000000        # Deposit 1 vBTC to long pool
  ./btcnft-issuer achieve-duration 1 wbtc DIAMOND_HANDS  # Claim achievement
  ./btcnft-issuer auction-purchase 1                # Purchase from Dutch auction

EOF
}

# Show version
show_version() {
    echo "BTCNFT Issuer CLI v${VERSION}"
}

# Main entrypoint
main() {
    # Handle global flags
    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --version|-v)
            show_version
            exit 0
            ;;
    esac

    # Parse network flag and get remaining args
    local args
    args=$(parse_network_args "$@")

    # Convert to array
    read -ra ARGS <<< "$args"

    # Get command
    local command="${ARGS[0]:-}"

    if [[ -z "$command" ]]; then
        show_help
        exit 1
    fi

    # Remove command from args
    REMAINING_ARGS=("${ARGS[@]:1}")
    export REMAINING_ARGS
    export CURRENT_NETWORK
    export COMMAND_NAME="btcnft-issuer $command"

    # Route to appropriate script
    case "$command" in
        # Mint Controllers
        mint-vault)
            exec "$CLI_DIR/commands/mint-vault.sh" "${REMAINING_ARGS[@]}"
            ;;
        mint-hybrid)
            exec "$CLI_DIR/commands/mint-hybrid.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Auctions
        auction-create-dutch)
            exec "$CLI_DIR/commands/auction-create-dutch.sh" "${REMAINING_ARGS[@]}"
            ;;
        auction-create-english)
            exec "$CLI_DIR/commands/auction-create-english.sh" "${REMAINING_ARGS[@]}"
            ;;
        auction-purchase)
            exec "$CLI_DIR/commands/auction-purchase.sh" "${REMAINING_ARGS[@]}"
            ;;
        auction-bid)
            exec "$CLI_DIR/commands/auction-bid.sh" "${REMAINING_ARGS[@]}"
            ;;
        auction-settle)
            exec "$CLI_DIR/commands/auction-settle.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Perpetuals
        perp-open)
            exec "$CLI_DIR/commands/perp-open.sh" "${REMAINING_ARGS[@]}"
            ;;
        perp-close)
            exec "$CLI_DIR/commands/perp-close.sh" "${REMAINING_ARGS[@]}"
            ;;
        perp-add-collateral)
            exec "$CLI_DIR/commands/perp-add-collateral.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Volatility Pool
        vol-deposit)
            exec "$CLI_DIR/commands/vol-deposit.sh" "${REMAINING_ARGS[@]}"
            ;;
        vol-withdraw)
            exec "$CLI_DIR/commands/vol-withdraw.sh" "${REMAINING_ARGS[@]}"
            ;;
        vol-settle)
            exec "$CLI_DIR/commands/vol-settle.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Achievements
        achieve-minter)
            exec "$CLI_DIR/commands/achieve-minter.sh" "${REMAINING_ARGS[@]}"
            ;;
        achieve-matured)
            exec "$CLI_DIR/commands/achieve-matured.sh" "${REMAINING_ARGS[@]}"
            ;;
        achieve-duration)
            exec "$CLI_DIR/commands/achieve-duration.sh" "${REMAINING_ARGS[@]}"
            ;;
        achieve-hodler-supreme)
            exec "$CLI_DIR/commands/achieve-hodler-supreme.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Chapters
        chapter-claim)
            exec "$CLI_DIR/commands/chapter-claim.sh" "${REMAINING_ARGS[@]}"
            ;;
        chapter-create)
            exec "$CLI_DIR/commands/chapter-create.sh" "${REMAINING_ARGS[@]}"
            ;;
        chapter-add-achievement)
            exec "$CLI_DIR/commands/chapter-add-achievement.sh" "${REMAINING_ARGS[@]}"
            ;;
        chapter-set-active)
            exec "$CLI_DIR/commands/chapter-set-active.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Profile & Dashboard
        profile-create)
            exec "$CLI_DIR/commands/profile-create.sh" "${REMAINING_ARGS[@]}"
            ;;
        dashboard-mint)
            exec "$CLI_DIR/commands/dashboard-mint.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Streaming
        stream-configure)
            exec "$CLI_DIR/commands/stream-configure.sh" "${REMAINING_ARGS[@]}"
            ;;
        stream-create)
            exec "$CLI_DIR/commands/stream-create.sh" "${REMAINING_ARGS[@]}"
            ;;
        stream-batch)
            exec "$CLI_DIR/commands/stream-batch.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Treasure NFT
        treasure-mint)
            exec "$CLI_DIR/commands/treasure-mint.sh" "${REMAINING_ARGS[@]}"
            ;;
        treasure-authorize)
            exec "$CLI_DIR/commands/treasure-authorize.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Queries
        auction-status)
            exec "$CLI_DIR/queries/auction-status.sh" "${REMAINING_ARGS[@]}"
            ;;
        perp-position)
            exec "$CLI_DIR/queries/perp-position.sh" "${REMAINING_ARGS[@]}"
            ;;
        perp-market)
            exec "$CLI_DIR/queries/perp-market.sh" "${REMAINING_ARGS[@]}"
            ;;
        vol-pool-status)
            exec "$CLI_DIR/queries/vol-pool-status.sh" "${REMAINING_ARGS[@]}"
            ;;
        vol-position)
            exec "$CLI_DIR/queries/vol-position.sh" "${REMAINING_ARGS[@]}"
            ;;
        achieve-check)
            exec "$CLI_DIR/queries/achieve-check.sh" "${REMAINING_ARGS[@]}"
            ;;
        achieve-status)
            exec "$CLI_DIR/queries/achieve-status.sh" "${REMAINING_ARGS[@]}"
            ;;
        chapter-claimable)
            exec "$CLI_DIR/queries/chapter-claimable.sh" "${REMAINING_ARGS[@]}"
            ;;
        chapter-info)
            exec "$CLI_DIR/queries/chapter-info.sh" "${REMAINING_ARGS[@]}"
            ;;
        profile-status)
            exec "$CLI_DIR/queries/profile-status.sh" "${REMAINING_ARGS[@]}"
            ;;
        dashboard-features)
            exec "$CLI_DIR/queries/dashboard-features.sh" "${REMAINING_ARGS[@]}"
            ;;
        stream-status)
            exec "$CLI_DIR/queries/stream-status.sh" "${REMAINING_ARGS[@]}"
            ;;
        treasure-status)
            exec "$CLI_DIR/queries/treasure-status.sh" "${REMAINING_ARGS[@]}"
            ;;

        # Unknown command
        *)
            echo "Error: Unknown command '$command'" >&2
            echo "Run './btcnft-issuer --help' for usage" >&2
            exit 1
            ;;
    esac
}

main "$@"
